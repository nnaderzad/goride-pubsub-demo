// GoRide trip events - each object is a single, valid message body for the
// rides topic.
//
// The topic has an Avro schema with JSON encoding, so the message you publish
// (from the console Messages tab OR via gcloud) must match these fields exactly:
// event_id, user_id, rider_email, driver_id, event_type (string), fare (number),
// city (string), timestamp (string). A typo or missing field is REJECTED at
// publish time - that's the schema doing its job. Copy ONE object (the inner
// {...}) as the message body.
//
// rider_email is the PII field: billing-sub delivers it in full, but the SMT on
// analytics-sub masks it before BigQuery (maya@example.com -> m***@example.com).
//
// Cast: evt_maya is THE live event - Maya (u_456), $24.50 across San Francisco,
// published on stage in Scene 3. The evt_1xxx events are "earlier rides tonight,"
// pre-baked during setup so the BigQuery dashboard already has traffic.
// evt_bad is the buggy-partner-app event for Scene 6 - fare as text, so the
// schema rejects it. That one SHOULD fail.

[
  {
    "event_id": "evt_maya",
    "user_id": "u_456",
    "rider_email": "maya@example.com",
    "driver_id": "d_789",
    "event_type": "trip_completed",
    "fare": 24.50,
    "city": "San Francisco",
    "timestamp": "2026-07-22T22:15:00Z"
  },
  {
    "event_id": "evt_1001",
    "user_id": "u_910",
    "rider_email": "jordan@example.com",
    "driver_id": "d_233",
    "event_type": "trip_completed",
    "fare": 8.75,
    "city": "Oakland",
    "timestamp": "2026-07-22T21:48:30Z"
  },
  {
    "event_id": "evt_1002",
    "user_id": "u_128",
    "rider_email": "sam@example.com",
    "driver_id": "d_512",
    "event_type": "trip_completed",
    "fare": 41.20,
    "city": "San Jose",
    "timestamp": "2026-07-22T21:55:05Z"
  },
  {
    "event_id": "evt_bad",
    "user_id": "u_999",
    "rider_email": "partner-bot@example.com",
    "driver_id": "d_000",
    "event_type": "trip_completed",
    "fare": "not-a-number",
    "city": "Nowhere",
    "timestamp": "2026-07-22T22:20:00Z"
  }
]
